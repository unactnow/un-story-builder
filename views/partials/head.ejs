<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="robots" content="noindex, nofollow">
    <title><%= typeof title !== 'undefined' ? title : 'UN Peace Dictionary' %></title>
    <link rel="icon" type="image/svg+xml" href="https://upload.wikimedia.org/wikipedia/commons/e/ee/UN_emblem_blue.svg">
    <link rel="icon" type="image/png" sizes="32x32" href="https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/UN_emblem_blue.svg/32px-UN_emblem_blue.svg.png">
    <link rel="apple-touch-icon" href="https://upload.wikimedia.org/wikipedia/commons/thumb/e/ee/UN_emblem_blue.svg/180px-UN_emblem_blue.svg.png">
    <link rel="stylesheet" href="/css/admin.css">
</head>
<body>
    <main class="admin-main" style="padding-top: 3rem;">
        <% if (typeof error_msg !== 'undefined' && error_msg.length > 0) { %>
            <% error_msg.forEach(msg => { %>
                <div class="flash flash-error"><%= msg %></div>
            <% }) %>
        <% } %>
