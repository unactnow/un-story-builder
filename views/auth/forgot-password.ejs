<%- include('../partials/head') %>

<div class="auth-form">
    <h1>Forgot password</h1>
    <p class="text-muted mb-2">Enter your email address and we'll send you a reset link.</p>
    <form method="POST" action="/auth/forgot-password">
        <input type="hidden" name="_csrf_token" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">
        <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required autofocus>
        </div>
        <button type="submit" class="btn btn-primary">Send reset link</button>
    </form>
    <p class="auth-link"><a href="/auth/login">Back to login</a></p>
</div>

<%- include('../partials/footer') %>
