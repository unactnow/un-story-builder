<%- include('../partials/admin-head') %>

<h2>Feature stories</h2>
<p><a href="/admin/stories/new" class="btn">Create new story</a></p>

<table class="admin-table">
  <thead>
    <tr>
      <th>Title</th>
      <th>Blocks</th>
      <th>Last updated</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% stories.forEach(function(s) { %>
    <tr>
      <td><a href="/admin/stories/<%= s.id %>/edit"><%= s.title %></a></td>
      <td><%= typeof s.blocksCount !== 'undefined' ? s.blocksCount : '—' %></td>
      <td><%= s.updatedAt ? new Date(s.updatedAt).toLocaleString() : '—' %></td>
      <td class="admin-table-actions">
        <a href="/admin/stories/<%= s.id %>/edit" class="btn btn-sm">Edit</a>
        <a href="/admin/stories/<%= s.id %>/export" class="btn btn-sm js-export-nav">Export</a>
        <form method="post" action="/admin/stories/<%= s.id %>/delete" class="inline-delete-form" onsubmit="return confirm('Delete this story permanently?');">
          <input type="hidden" name="_csrf_token" value="<%= csrfToken %>">
          <button type="submit" class="list-delete-link">Delete</button>
        </form>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>

<% if (stories.length === 0) { %>
<p>No stories yet.</p>
<% } %>

<script src="/js/export-link-loading.js"></script>
<%- include('../partials/admin-footer') %>
