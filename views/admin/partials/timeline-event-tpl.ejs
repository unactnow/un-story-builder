<% var e = event; %>
<div class="event-card drag-item expanded" data-id="<%= e.id || '' %>" draggable="true">
  <div class="event-card-header">
    <span class="drag-handle" title="Drag to reorder">&#9776;</span>
    <span class="event-date-badge">—</span>
    <span class="event-summary">New event</span>
    <div class="block-actions">
      <button type="button" class="btn-move-up">Up</button>
      <button type="button" class="btn-move-down">Down</button>
      <button type="button" class="btn-remove">Remove</button>
    </div>
  </div>
  <div class="event-card-body">
    <input type="hidden" name="events[__INDEX__][sortOrder]" class="sort-order-input" value="__INDEX__">
    <% if (e.id) { %><input type="hidden" name="events[__INDEX__][id]" value="<%= e.id %>"><% } %>
    <p><label>Date<br><input type="text" name="events[__INDEX__][dateText]" value="<%= e.dateText || '' %>" class="wide"></label></p>
    <p><label>Location<br><input type="text" name="events[__INDEX__][location]" value="<%= e.location || '' %>" class="wide"></label></p>
    <p><label>Event title *<br><input type="text" name="events[__INDEX__][heading]" value="<%= e.heading || '' %>" class="wide"></label></p>
    <p><label>Event description</label></p>
    <%- include('./wysiwyg-inner', { name: 'events[__INDEX__][description]', value: e.description }) %>
    <p><label>Image URL (optional)<br><input type="text" name="events[__INDEX__][imageUrl]" value="<%= e.imageUrl || '' %>" class="wide img-url"></label></p>
    <p><label>Image alt text<br><input type="text" name="events[__INDEX__][imageAlt]" value="<%= e.imageAlt || '' %>" class="wide"></label></p>
    <p><label>Image caption<br><input type="text" name="events[__INDEX__][imageCaption]" value="<%= e.imageCaption || '' %>" class="wide"></label></p>
  </div>
</div>
