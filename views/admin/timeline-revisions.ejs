<%- include('../partials/admin-head') %>

<h2>Revisions: <%= timeline.title %></h2>
<p><a href="/admin/timelines/<%= timeline.id %>/edit">Back to edit</a></p>

<table class="admin-table">
  <thead>
    <tr>
      <th>Date</th>
      <th>Revised By</th>
      <th>Actions</th>
    </tr>
  </thead>
  <tbody>
    <% revisions.forEach(function(rev) { %>
    <tr>
      <td><%= rev.createdAt ? new Date(rev.createdAt).toLocaleString() : '—' %></td>
      <td><%= rev.revisedBy || '—' %></td>
      <td>
        <form method="post" action="/admin/timelines/<%= timeline.id %>/revisions/<%= rev.id %>/restore" style="display:inline;" onsubmit="return confirm('Restore this revision? Current content will be saved as a new revision first.');">
          <input type="hidden" name="_csrf_token" value="<%= csrfToken %>">
          <button type="submit" class="btn btn-outline btn-sm">Restore</button>
        </form>
      </td>
    </tr>
    <% }); %>
  </tbody>
</table>

<% if (!revisions || revisions.length === 0) { %>
<p>No revisions yet.</p>
<% } %>

<%- include('../partials/admin-footer') %>
