<%- include('../partials/admin-head') %>
<link rel="stylesheet" href="/css/quill-snow.css">

<h2><%= timeline ? 'Edit timeline' : 'New timeline' %><% if (timeline && revisionCount > 0) { %> <span class="title-meta">(<a href="/admin/timelines/<%= timeline.id %>/revisions"><%= revisionCount %> revision<%= revisionCount !== 1 ? 's' : '' %></a>)</span><% } %></h2>

<form method="post" action="<%= timeline ? '/admin/timelines/' + timeline.id + '/edit' : '/admin/timelines/new' %>" id="timeline-form" class="term-edit-layout" data-has-delete="<%= timeline ? 'true' : 'false' %>">
  <input type="hidden" name="_csrf_token" value="<%= csrfToken %>">

  <div class="term-edit-form-col">
    <div class="form-row">
      <label for="title">Title *</label>
      <input type="text" id="title" name="title" required value="<%= timeline ? timeline.title : '' %>" class="wide">
    </div>
    <div class="form-row">
      <p><label>Description</label></p>
      <%- include('./partials/wysiwyg-inner', { name: 'description', value: timeline ? (timeline.description || '') : '' }) %>
      <span class="hint">Subtitle shown in the timeline header when exported.</span>
    </div>

    <div class="btn-row">
      <button type="submit" class="btn btn-save">Save</button>
      <% if (timeline) { %>
      <button type="button" class="btn btn-outline btn-preview-timeline" title="Save your edits and go to the preview">Preview</button>
      <a href="/admin/timelines/<%= timeline.id %>/export" class="btn btn-outline btn-export-timeline">Export</a>
      <% } %>
    </div>

    <h3>Events</h3>
    <div id="event-list" class="block-list" data-drag-container data-reorder-url="<%= timeline ? '/admin/timelines/' + timeline.id + '/events/reorder' : '' %>" data-reorder-id-key="eventIds">
      <% events.forEach(function(ev, i) { %>
      <%- include('./partials/timeline-event', { event: ev, index: i }) %>
      <% }); %>
    </div>

    <p><button type="button" class="btn btn-outline" id="btn-add-event">Add event</button></p>

    <% if (timeline) { %>
    <div class="form-actions-bottom">
      <div class="btn-row">
        <button type="submit" class="btn btn-save">Save</button>
        <button type="button" class="btn btn-outline btn-preview-timeline" title="Save your edits and go to the preview">Preview</button>
        <a href="/admin/timelines/<%= timeline.id %>/export" class="btn btn-outline btn-export-timeline">Export</a>
      </div>
      <div class="btn-row btn-row-delete">
        <button type="button" class="btn btn-outline" style="color:var(--color-error);border-color:var(--color-error);" id="btn-delete-timeline">Delete timeline</button>
      </div>
    </div>
    <% } %>
  </div>

  <div class="term-edit-preview-col">
    <div class="md-guide">
      <h3>About timelines</h3>
      <p class="hint" style="margin:0;">A timeline is a dated list of events with optional images. Build the sequence here; export produces standalone HTML that matches the UN feature styles.</p>
      <h3>Images and media</h3>
      <p class="hint" style="margin:0;">To add images/media to your timeline, upload your files to the UN website through Drupal, then copy the public URL and paste it into the matching field here (image URL, video URL, etc.).</p>
      <h3>Exporting HTML</h3>
      <ol>
        <li>Use <strong>Preview</strong> to save your draft and open the rendered HTML in this window, or click <strong>Save</strong> to store edits without leaving this page</li>
        <li>Click <strong>Export</strong> (or open Export after saving from the timelines list)</li>
        <li>On the export page, use <strong>Copy to clipboard</strong> or <strong>Download HTML</strong></li>
        <li>Paste or upload the generated HTML into Drupal (or your target page) according to your team’s publishing process</li>
      </ol>
    </div>
  </div>
</form>

<% if (timeline) { %>
<form method="post" action="/admin/timelines/<%= timeline.id %>/delete" id="delete-timeline-form" style="display:none;">
  <input type="hidden" name="_csrf_token" value="<%= csrfToken %>">
</form>
<% } %>

<template id="tpl-timeline-event">
<%- include('./partials/timeline-event-tpl', { event: { dateText: '', location: '', heading: '', description: '', imageUrl: '', imageAlt: '', imageCaption: '' } }) %>
</template>

<script src="/js/drag-reorder.js"></script>
<script src="https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.js"></script>
<script src="/js/quill-admin.js"></script>
<script src="/js/timeline-edit.js"></script>

<%- include('../partials/admin-footer') %>
