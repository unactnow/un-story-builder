<%- include('../partials/admin-head') %>

<h2>Export: <%= story.title %></h2>
<p><%= typeof blocksCount !== 'undefined' ? blocksCount : 0 %> blocks · Exported <%= new Date().toISOString() %></p>

<div class="btn-row">
  <button type="button" class="btn" id="btn-copy-export">Copy to clipboard</button>
  <a href="/admin/stories/<%= story.id %>/export/download" class="btn btn-outline">Download HTML</a>
</div>

<pre class="export-pre"><code><%= htmlOutput %></code></pre>

<p><a href="/admin/stories/<%= story.id %>/edit">Back to edit</a></p>

<script type="application/json" id="export-data"><%- JSON.stringify(htmlOutput).replace(/</g, '\\u003c') %></script>
<script src="/js/export-clipboard.js"></script>

<%- include('../partials/admin-footer') %>
