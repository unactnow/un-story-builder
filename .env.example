# Database (Neon PostgreSQL — required; use pooled connection string on Vercel)
DATABASE_URL=

# Shared users + password_reset_tokens (same URI in un-social-feed, un-story-builder, un-peace-dictionary).
# Omit to keep users on DATABASE_URL (legacy).
# AUTH_DATABASE_URL=

# Optional: Postgres URL that already has Story Builder data — used by npm run migrate:local
# to copy users/stories/timelines into DATABASE_URL. Omit to only pull users+settings from database.sqlite.
# Optional: Peace Dictionary (or any same-schema app) DB — used by npm run copy:users
# SOURCE_DATABASE_URL=

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production

# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
# Admin preview loads /export/*.css|js from your deployed app (same origin). Downloaded/export HTML
# uses jsDelivr (GitHub) for /export/* assets only if the repo is public and files exist on the branch.
# Private repo → jsDelivr 404; set a public base instead, e.g.
# EXPORT_ASSET_BASE_URL=https://your-app.vercel.app
# (no trailing slash; final URL is …/export/styles.css)
# EXPORT_ASSET_BASE_URL=
# EXPORT_JSDELIVR_REPO=unactnow/un-story-builder
# EXPORT_JSDELIVR_REF=main

# SMTP (leave blank to log reset URLs to console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Seed script (used by npm run seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
