# Database (Neon PostgreSQL — leave blank to use local SQLite)
DATABASE_URL=

# Session
SESSION_SECRET=your-super-secret-session-key-change-in-production

# App
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
# Export HTML loads /public/export/*.css|js via jsDelivr by default (see helpers/exportAssetUrls.js).
# Override the full origin + path prefix if needed (must end before /export/styles.css), e.g. https://cdn.jsdelivr.net/gh/you/fork@main/public
# EXPORT_ASSET_BASE_URL=
# EXPORT_JSDELIVR_REPO=unactnow/un-feature-stories-timelines
# EXPORT_JSDELIVR_REF=main

# SMTP (leave blank to log reset URLs to console instead)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Seed script (used by npm run seed)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin
